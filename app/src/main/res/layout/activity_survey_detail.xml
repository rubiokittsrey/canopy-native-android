<?xml version="1.0" encoding="utf-8"?>
<androidx.coordinatorlayout.widget.CoordinatorLayout
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:fitsSystemWindows="true"
    tools:context=".views.activities.SurveyDetailActivity">

    <com.google.android.material.appbar.AppBarLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:fitsSystemWindows="true">

        <com.google.android.material.appbar.MaterialToolbar
            android:id="@+id/toolbar"
            android:layout_width="match_parent"
            android:layout_height="?attr/actionBarSize"
            app:title="@string/survey_detail"
            app:titleTextColor="@color/text_on_primary"
            android:background="@color/primary"
            app:navigationIcon="@drawable/ic_back"
            app:navigationIconTint="@color/text_on_primary"
            app:menu="@menu/menu_survey_detail"/>

    </com.google.android.material.appbar.AppBarLayout>

    <androidx.core.widget.NestedScrollView
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        app:layout_behavior="@string/appbar_scrolling_view_behavior">

        <LinearLayout
            android:layout_width="match_parent"
            android:layout_height="wrap_content"
            android:orientation="vertical"
            android:padding="@dimen/spacing_md">

            <!-- Sync Status Banner -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSyncStatus"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/card_corner_radius"
                android:visibility="gone"
                tools:visibility="visible">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="horizontal"
                    android:gravity="center_vertical"
                    android:padding="@dimen/spacing_md">

                    <ImageView
                        android:id="@+id/imageSyncStatus"
                        android:layout_width="@dimen/icon_md"
                        android:layout_height="@dimen/icon_md"
                        android:src="@drawable/ic_cloud_upload"
                        tools:ignore="ContentDescription"/>

                    <TextView
                        android:id="@+id/textSyncStatus"
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:layout_marginStart="@dimen/spacing_sm"
                        android:textAppearance="@style/TextAppearance.Canopy.Body"
                        tools:text="Pending sync"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Metadata Section -->
            <com.google.android.material.card.MaterialCardView
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation">

                <LinearLayout
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/metadata"
                        android:textAppearance="@style/TextAppearance.Canopy.Title"
                        android:textColor="@color/primary"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="@dimen/spacing_sm"
                        android:background="@color/divider"/>

                    <!-- Survey Type -->
                    <include
                        android:id="@+id/rowSurveyType"
                        layout="@layout/item_detail_row"/>

                    <!-- Observer -->
                    <include
                        android:id="@+id/rowObserver"
                        layout="@layout/item_detail_row"/>

                    <!-- Organization -->
                    <include
                        android:id="@+id/rowOrganization"
                        layout="@layout/item_detail_row"/>

                    <!-- Date -->
                    <include
                        android:id="@+id/rowDate"
                        layout="@layout/item_detail_row"/>

                    <!-- Time -->
                    <include
                        android:id="@+id/rowTime"
                        layout="@layout/item_detail_row"/>

                    <!-- Weather -->
                    <include
                        android:id="@+id/rowWeather"
                        layout="@layout/item_detail_row"/>

                    <!-- Method -->
                    <include
                        android:id="@+id/rowMethod"
                        layout="@layout/item_detail_row"/>

                    <!-- Location -->
                    <include
                        android:id="@+id/rowLocation"
                        layout="@layout/item_detail_row"/>

                    <!-- Notes -->
                    <include
                        android:id="@+id/rowNotes"
                        layout="@layout/item_detail_row"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Topographic Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardTopographic"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/layoutTopographic"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/topographic"
                        android:textAppearance="@style/TextAppearance.Canopy.Title"
                        android:textColor="@color/primary"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="@dimen/spacing_sm"
                        android:background="@color/divider"/>

                    <!-- Dynamic content will be added here -->

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Vegetation Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardVegetation"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/layoutVegetation"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/vegetation"
                        android:textAppearance="@style/TextAppearance.Canopy.Title"
                        android:textColor="@color/primary"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="@dimen/spacing_sm"
                        android:background="@color/divider"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Soil Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardSoil"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/layoutSoil"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/soil"
                        android:textAppearance="@style/TextAppearance.Canopy.Title"
                        android:textColor="@color/primary"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="@dimen/spacing_sm"
                        android:background="@color/divider"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Water Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardWater"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/layoutWater"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/water"
                        android:textAppearance="@style/TextAppearance.Canopy.Title"
                        android:textColor="@color/primary"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="@dimen/spacing_sm"
                        android:background="@color/divider"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Biodiversity Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardBiodiversity"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/layoutBiodiversity"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/biodiversity"
                        android:textAppearance="@style/TextAppearance.Canopy.Title"
                        android:textColor="@color/primary"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="@dimen/spacing_sm"
                        android:background="@color/divider"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Hazard Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardHazard"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/layoutHazard"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/hazard"
                        android:textAppearance="@style/TextAppearance.Canopy.Title"
                        android:textColor="@color/primary"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="@dimen/spacing_sm"
                        android:background="@color/divider"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

            <!-- Infrastructure Section -->
            <com.google.android.material.card.MaterialCardView
                android:id="@+id/cardInfrastructure"
                android:layout_width="match_parent"
                android:layout_height="wrap_content"
                android:layout_marginBottom="@dimen/spacing_md"
                app:cardCornerRadius="@dimen/card_corner_radius"
                app:cardElevation="@dimen/card_elevation"
                android:visibility="gone">

                <LinearLayout
                    android:id="@+id/layoutInfrastructure"
                    android:layout_width="match_parent"
                    android:layout_height="wrap_content"
                    android:orientation="vertical"
                    android:padding="@dimen/spacing_md">

                    <TextView
                        android:layout_width="wrap_content"
                        android:layout_height="wrap_content"
                        android:text="@string/infrastructure"
                        android:textAppearance="@style/TextAppearance.Canopy.Title"
                        android:textColor="@color/primary"/>

                    <View
                        android:layout_width="match_parent"
                        android:layout_height="1dp"
                        android:layout_marginVertical="@dimen/spacing_sm"
                        android:background="@color/divider"/>

                </LinearLayout>

            </com.google.android.material.card.MaterialCardView>

        </LinearLayout>

    </androidx.core.widget.NestedScrollView>

    <!-- Loading Overlay -->
    <FrameLayout
        android:id="@+id/layoutLoading"
        android:layout_width="match_parent"
        android:layout_height="match_parent"
        android:background="#80FFFFFF"
        android:clickable="true"
        android:focusable="true"
        android:visibility="gone">

        <ProgressBar
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_gravity="center"/>

    </FrameLayout>

</androidx.coordinatorlayout.widget.CoordinatorLayout>