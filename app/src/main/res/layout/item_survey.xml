<?xml version="1.0" encoding="utf-8"?>
<com.google.android.material.card.MaterialCardView
    xmlns:android="http://schemas.android.com/apk/res/android"
    xmlns:app="http://schemas.android.com/apk/res-auto"
    xmlns:tools="http://schemas.android.com/tools"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:layout_marginHorizontal="@dimen/spacing_md"
    android:layout_marginVertical="@dimen/spacing_sm"
    app:cardCornerRadius="@dimen/card_corner_radius"
    app:cardElevation="@dimen/card_elevation"
    app:strokeWidth="0dp"
    android:clickable="true"
    android:focusable="true"
    android:foreground="?attr/selectableItemBackground">

    <androidx.constraintlayout.widget.ConstraintLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:padding="@dimen/spacing_md">

        <!-- Survey Type / Title -->
        <TextView
            android:id="@+id/textSurveyType"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Canopy.Title"
            android:textSize="@dimen/text_size_lg"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toTopOf="parent"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/imageSyncStatus"
            tools:text="Full Environmental Survey"/>

        <!-- Sync Status Indicator -->
        <ImageView
            android:id="@+id/imageSyncStatus"
            android:layout_width="@dimen/sync_indicator_size"
            android:layout_height="@dimen/sync_indicator_size"
            android:src="@drawable/ic_cloud_done"
            android:contentDescription="@string/cd_sync_status"
            app:layout_constraintTop_toTopOf="@id/textSurveyType"
            app:layout_constraintBottom_toBottomOf="@id/textSurveyType"
            app:layout_constraintEnd_toEndOf="parent"
            app:tint="@color/sync_synced"/>

        <!-- Observer Name -->
        <TextView
            android:id="@+id/textObserver"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:textAppearance="@style/TextAppearance.Canopy.Body"
            android:textColor="@color/text_primary"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/textSurveyType"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="Maria Santos"/>

        <!-- Organization -->
        <TextView
            android:id="@+id/textOrganization"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:textAppearance="@style/TextAppearance.Canopy.Caption"
            android:maxLines="1"
            android:ellipsize="end"
            app:layout_constraintTop_toBottomOf="@id/textObserver"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="PhilGIS Environmental Services"/>

        <!-- Divider -->
        <View
            android:id="@+id/divider"
            android:layout_width="match_parent"
            android:layout_height="1dp"
            android:layout_marginTop="@dimen/spacing_sm"
            android:background="@color/divider"
            app:layout_constraintTop_toBottomOf="@id/textOrganization"/>

        <!-- Date and Time -->
        <TextView
            android:id="@+id/textDateTime"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:textAppearance="@style/TextAppearance.Canopy.Caption"
            android:drawablePadding="@dimen/spacing_xs"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toStartOf="@id/textWeather"
            tools:text="2026-03-07 • 09:15"/>

        <!-- Weather Badge -->
        <TextView
            android:id="@+id/textWeather"
            android:layout_width="wrap_content"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_sm"
            android:background="@drawable/bg_weather_badge"
            android:textAppearance="@style/TextAppearance.Canopy.Caption"
            android:textColor="@color/text_secondary"
            android:textSize="@dimen/text_size_xs"
            app:layout_constraintTop_toBottomOf="@id/divider"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="Cloudy"/>

        <!-- Location (Coordinates) -->
        <TextView
            android:id="@+id/textLocation"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_marginTop="@dimen/spacing_xs"
            android:textAppearance="@style/TextAppearance.Canopy.Caption"
            android:drawablePadding="@dimen/spacing_xs"
            app:drawableStartCompat="@drawable/ic_location"
            app:drawableTint="@color/text_hint"
            app:layout_constraintTop_toBottomOf="@id/textDateTime"
            app:layout_constraintStart_toStartOf="parent"
            app:layout_constraintEnd_toEndOf="parent"
            tools:text="8.4542, 124.6319"/>

    </androidx.constraintlayout.widget.ConstraintLayout>

</com.google.android.material.card.MaterialCardView>